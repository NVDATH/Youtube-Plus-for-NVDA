#. Translators: error in Youtube playlist page
#: addon/globalPlugins/YoutubePlus/core.py:343
msgid "This command is for videos, but the current page is a playlist."
msgstr "คำสั่งนี้ใช้สำหรับวิดีโอ แต่หน้าปัจจุบันคือเพลย์ลิสต์"

#. Translators: error in not video page
#: addon/globalPlugins/YoutubePlus/core.py:350
msgid "This command is for videos, but the current page appears to be a channel or playlist."
msgstr "คำสั่งนี้ใช้สำหรับวิดีโอ แต่หน้าปัจจุบันดูเหมือนจะเป็นช่องหรือเพลย์ลิสต์"

#. Translators: anouce for YoutubePlus main layer command
#: addon/globalPlugins/YoutubePlus/core.py:647
msgid "activate YoutubePlus"
msgstr "เปิดใช้งาน YoutubePlus"

#. Translators: Message shown when a Super Chat is received, indicating the amount and the sender's message.
#: addon/globalPlugins/YoutubePlus/core.py:746
#, python-brace-format
msgid "Super Chat ({amount}): {paid_message}"
msgstr "ซูเปอร์แชท ({amount}):{paid_message}"

#. Translators: Message shown when a Super Sticker is received, indicating the amount.
#: addon/globalPlugins/YoutubePlus/core.py:760
#, python-brace-format
msgid "Super Sticker ({amount})"
msgstr "ซุปเปอร์สติ๊กเกอร์ ({amount})"

#. Translators: Label for a system-generated message or author from YouTube, with the type of icon/badge in parentheses.
#: addon/globalPlugins/YoutubePlus/core.py:791
#, python-brace-format
msgid "YouTube System ({icon_type})"
msgstr "ระบบ YouTube ({icon_type})"

#. Translators: Label for duration in hours when the value is exactly 1.
#: addon/globalPlugins/YoutubePlus/core.py:813
#, python-brace-format
msgid "{h} Hour"
msgstr "{h}ชั่วโมง"

#. Translators: Label for duration in hours when the value is greater than 1.
#: addon/globalPlugins/YoutubePlus/core.py:815
#, python-brace-format
msgid "{h} Hours"
msgstr "{h}ชั่วโมง"

#. Translators: Label for duration in minutes when the value is exactly 1.
#. Translators: Label for duration in minutes when the value is other than 1.
#: addon/globalPlugins/YoutubePlus/core.py:820
#, python-brace-format
msgid "{m} Minute"
msgstr "{m}นาที"

#: addon/globalPlugins/YoutubePlus/core.py:820
#, python-brace-format
msgid "{m} Minutes"
msgstr "{m}นาที"

#. Translators: Label for duration in seconds when the value is exactly 1.
#. Translators: Label for duration in seconds when the value is 0 or more than 1.
#: addon/globalPlugins/YoutubePlus/core.py:823
#, python-brace-format
msgid "{s} Second"
msgstr "{s}วินาที"

#: addon/globalPlugins/YoutubePlus/core.py:823
#, python-brace-format
msgid "{s} Seconds"
msgstr "{s}วินาที"

#. Translators: Title of a dialog box that displays information about a specific video.
#: addon/globalPlugins/YoutubePlus/core.py:858
#, python-brace-format
msgid "Info of {title}"
msgstr "ข้อมูลของ{title}"

#. Translators: The message in a dialog box asking the user whether they want to view the live chat replay.
#. Translators: The title (caption) of the choice dialog box.
#: addon/globalPlugins/YoutubePlus/core.py:875
msgid "This video has a live chat replay. What would you like to view?"
msgstr "วิดีโอนี้มีการเล่นแชทสดซ้ำคุณอยากจะดูอะไร?"

#: addon/globalPlugins/YoutubePlus/core.py:875
msgid "Choice"
msgstr "ทางเลือก"

#. Translators: Label for a button to show comments, including the total count. The '&' indicates the keyboard shortcut.
#. Translators: Label for a button to show the live chat replay. The '&' indicates the keyboard shortcut.
#. Translators: Label for the cancel button. The '&' indicates the keyboard shortcut.
#: addon/globalPlugins/YoutubePlus/core.py:879
#, python-brace-format
msgid "Show {comment_count} &Comments"
msgstr "แสดง &ความคิดเห็น{comment_count}"

#: addon/globalPlugins/YoutubePlus/core.py:879
msgid "Show &Live Chat Replay"
msgstr "แสดง &เล่นแชทสดซ้ำ"

#. Translators: Button to cancel the search and close the dialog.
#: addon/globalPlugins/YoutubePlus/core.py:879 addon/globalPlugins/YoutubePlus/core.py:1782
#: addon/globalPlugins/YoutubePlus/dialogs.py:2070
msgid "Ca&ncel"
msgstr "ยกเลิก"

#. Translators: Error message shown to the user when the add-on fails to retrieve video information.
#: addon/globalPlugins/YoutubePlus/core.py:928
msgid ""
"Failed to get video data. The video may be private, unavailable, or there was a network "
"issue."
msgstr "ไม่สามารถรับข้อมูลวิดีโอวิดีโออาจเป็นส่วนตัว ไม่พร้อมใช้งาน หรือมีปัญหาเครือข่าย"

#. Translators: General error message shown to the user when an unknown or unhandled problem occurs.
#: addon/globalPlugins/YoutubePlus/core.py:932
msgid "An unexpected error occurred."
msgstr "เกิดข้อผิดพลาดที่ไม่คาดคิด"

#. Translators: Notification shown when the add-on finds that the selected video has zero comments.
#: addon/globalPlugins/YoutubePlus/core.py:949
msgid "This video has no comments."
msgstr "วิดีโอนี้ไม่มีความคิดเห็น"

#. Translators: Status message shown when the add-on starts loading a specific number of comments.
#: addon/globalPlugins/YoutubePlus/core.py:953
#, python-brace-format
msgid "Loading {count} comments..."
msgstr "กำลังโหลดความคิดเห็น{count}รายการ..."

#. Translators: Status message shown when the add-on starts loading the live chat replay.
#: addon/globalPlugins/YoutubePlus/core.py:956
msgid "Loading live chat replay..."
msgstr "กำลังโหลดการเล่นแชทสดซ้ำ..."

#. Translators: Message shown when a user tries to get video info for a live stream,
#: addon/globalPlugins/YoutubePlus/core.py:970
msgid "Live stream detected. Please use the 'Monitor live chat' command instead."
msgstr "ตรวจพบสตรีมสดโปรดใช้คำสั่ง 'ตรวจสอบแชทสด' แทน"

#: addon/globalPlugins/YoutubePlus/core.py:986
#, python-brace-format
msgid "Title: {title}"
msgstr "ชื่อเรื่อง:{title}"

#: addon/globalPlugins/YoutubePlus/core.py:987
#, python-brace-format
msgid "Channel: {uploader}"
msgstr "ช่องทาง:{uploader}"

#: addon/globalPlugins/YoutubePlus/core.py:988
#, python-brace-format
msgid "Duration: {duration}"
msgstr "ระยะเวลา:{duration}"

#: addon/globalPlugins/YoutubePlus/core.py:989
#, python-brace-format
msgid "Uploaded: {upload_date}"
msgstr "อัปโหลดแล้ว:{upload_date}"

#: addon/globalPlugins/YoutubePlus/core.py:990
#, python-brace-format
msgid "Views: {view_count}"
msgstr "การดู:{view_count}"

#: addon/globalPlugins/YoutubePlus/core.py:991
#, python-brace-format
msgid "Likes: {like_count}"
msgstr "ชอบ:{like_count}"

#: addon/globalPlugins/YoutubePlus/core.py:992
#, python-brace-format
msgid "Comments: {comment_count}"
msgstr "ความคิดเห็น:{comment_count}"

#: addon/globalPlugins/YoutubePlus/core.py:994
#, python-brace-format
msgid ""
"Description:\n"
"{description}"
msgstr "คำอธิบาย:{description}"

#. Translators: Error message shown when the add-on cannot retrieve video details, possibly due to privacy settings or no internet connection.
#: addon/globalPlugins/YoutubePlus/core.py:1000
msgid "Failed to get video info. The video may be private or the network is down."
msgstr "ไม่สามารถรับข้อมูลวิดีโอวิดีโออาจเป็นแบบส่วนตัวหรือเครือข่ายล่ม"

#. Translators: General error message encouraging the user to check the log file for more technical information.
#: addon/globalPlugins/YoutubePlus/core.py:1004 addon/globalPlugins/YoutubePlus/core.py:1032
#: addon/globalPlugins/YoutubePlus/core.py:1082
msgid "An unexpected error occurred. Please check the log for details."
msgstr "เกิดข้อผิดพลาดที่ไม่คาดคิดโปรดตรวจสอบบันทึกเพื่อดูรายละเอียด"

#. Translators: Title of the dialog that displays a list of chapters for the current video.
#: addon/globalPlugins/YoutubePlus/core.py:1021
#, python-brace-format
msgid "Chapters for {title}"
msgstr "บทสำหรับ{title}"

#. Translators: Error message shown when the user tries to list chapters but the video doesn't have any.
#: addon/globalPlugins/YoutubePlus/core.py:1025
msgid "No chapters found in this video."
msgstr "ไม่พบบทในวิดีโอนี้"

#. Translators: Error message shown when chapters cannot be retrieved, possibly due to privacy settings or connection issues.
#: addon/globalPlugins/YoutubePlus/core.py:1028
msgid "Failed to get chapters. The video may be private or the network is down."
msgstr "ไม่สามารถรับบทได้วิดีโออาจเป็นแบบส่วนตัวหรือเครือข่ายล่ม"

#. Translators: Title of the dialog showing a list of comments, including the number of comments and the video title.
#: addon/globalPlugins/YoutubePlus/core.py:1051
#, python-brace-format
msgid "{count} comments of {title}"
msgstr "{count}ความคิดเห็นของ{title}"

#. Translators: Title of the dialog showing a list of live chat replay messages, including the count and the video title.
#: addon/globalPlugins/YoutubePlus/core.py:1068
#, python-brace-format
msgid "{count} live chat replay of {title}"
msgstr "{count}เล่นแชทสดซ้ำของ{title}"

#. Translators: Message shown when data loading fails, including the specific error message.
#: addon/globalPlugins/YoutubePlus/core.py:1077
#, python-brace-format
msgid "Could not load data: {error}"
msgstr "ไม่สามารถโหลดข้อมูล:{error}"

#. Translators: Message shown when the connection to a YouTube live chat is lost, often because the stream has ended.
#: addon/globalPlugins/YoutubePlus/core.py:1095
msgid "Connection to live chat lost. The stream may have ended."
msgstr "การเชื่อมต่อกับแชทสดขาดหายไปกระแสอาจจะจบลงแล้ว"

#. Translators: Notification shown when the add-on deletes older chat messages from memory to maintain performance.
#: addon/globalPlugins/YoutubePlus/core.py:1121
msgid "To conserve memory, older chat messages have been discarded."
msgstr "เพื่อเป็นการประหยัดหน่วยความจำ ข้อความแชทเก่าๆ จึงถูกละทิ้ง"

#. Translators: Message shown when the add-on starts receiving and displaying live chat messages for a specific video.
#: addon/globalPlugins/YoutubePlus/core.py:1129
#, python-brace-format
msgid "Receiving live chat of {video_title}"
msgstr "กำลังรับแชทสดของ{video_title}"

#. Translators: Error message shown when the live chat monitoring process encounters an issue and has to stop.
#: addon/globalPlugins/YoutubePlus/core.py:1139
msgid "An error occurred while receiving live chat. Monitoring stopped."
msgstr "เกิดข้อผิดพลาดขณะรับแชทสดหยุดการตรวจสอบแล้ว"

#. Translators: Notification shown when the live chat history has been successfully saved to a file.
#: addon/globalPlugins/YoutubePlus/core.py:1171
#, python-brace-format
msgid "Live chat saved to {filename}"
msgstr "บันทึกแชทสดไปที่{filename}"

#. Translators: Error message shown when the add-on fails to write the live chat history to a file.
#: addon/globalPlugins/YoutubePlus/core.py:1177
msgid "Failed to save chat history."
msgstr "ไม่สามารถบันทึกประวัติการแชทได้"

#. Translators: A prompt asking the user if they want to save the chat history after a live stream ends.
#. {count} is the number of messages collected.
#. The second string is the title of the confirmation dialog.
#: addon/globalPlugins/YoutubePlus/core.py:1196
#, python-brace-format
msgid ""
"The stream has ended. You have {count} chat messages.\n"
"\n"
"Would you like to save the chat history?"
msgstr ""
"สตรีมสิ้นสุดลงแล้วคุณมีข้อความแชท{count}\n"
"คุณต้องการบันทึกประวัติการแชทหรือไม่?"

#: addon/globalPlugins/YoutubePlus/core.py:1197
msgid "Save Chat History?"
msgstr "บันทึกประวัติการแชทไหม"

#. Translators: Error message shown when the add-on fails to start or continue receiving live chat messages.
#. Translators: Error message shown when the add-on fails to connect to the YouTube live chat.
#. {error} is the technical details of the failure.
#: addon/globalPlugins/YoutubePlus/core.py:1220 addon/globalPlugins/YoutubePlus/core.py:1920
#, python-brace-format
msgid "Could not receive live chat: {error}"
msgstr "ไม่สามารถรับแชทสด:{error}"

#. Translators: Status message shown when a video is being added to the favorites list.
#: addon/globalPlugins/YoutubePlus/core.py:1225
msgid "Adding to favorites..."
msgstr "กำลังเพิ่มในรายการโปรด..."

#. Translators: Error message shown when the user provides a link that is not a direct video URL (e.g., a playlist or channel link).
#: addon/globalPlugins/YoutubePlus/core.py:1232
msgid "The provided link is not for a single video."
msgstr "ลิงก์ที่ให้มาไม่ใช่สำหรับวิดีโอเดียว"

#. Translators: Message shown when the user tries to add a video to favorites that is already present in the list.
#: addon/globalPlugins/YoutubePlus/core.py:1245
msgid "This video is already in your favorites."
msgstr "วิดีโอนี้อยู่ในรายการโปรดของคุณแล้ว"

#. Translators: Success message shown after a video has been successfully added to the favorites list.
#. {title} is the name of the video.
#: addon/globalPlugins/YoutubePlus/core.py:1259
#, python-brace-format
msgid "Added '{title}' to favorites."
msgstr "เพิ่ม '{title}' ลงในรายการโปรด"

#. Translators: Error message shown to the user when a video could not be added to the favorites list.
#. Translators: Error message shown to the user when a channel could not be added to the favorites list.
#: addon/globalPlugins/YoutubePlus/core.py:1262 addon/globalPlugins/YoutubePlus/core.py:1316
msgid "Failed to add favorite."
msgstr "ไม่สามารถเพิ่มรายการโปรดได้"

#. Translators: Status message shown when a channel is being added to the favorites list.
#: addon/globalPlugins/YoutubePlus/core.py:1273
msgid "Adding to favorite channels..."
msgstr "กำลังเพิ่มไปยังช่องโปรด..."

#. Translators: Message shown when the user tries to add a channel to favorites that is already present in the list.
#: addon/globalPlugins/YoutubePlus/core.py:1299
msgid "This channel is already in your favorites."
msgstr "ช่องนี้อยู่ในรายการโปรดของคุณแล้ว"

#. Translators: Success message shown after a YouTube channel has been successfully added to the favorites list.
#. {channel} is the name of the channel.
#: addon/globalPlugins/YoutubePlus/core.py:1313
#, python-brace-format
msgid "Added '{channel}' to favorites."
msgstr "เพิ่ม '{channel}' ลงในรายการโปรด"

#. Translators: Status message shown when the add-on starts the process of adding a playlist to favorites.
#: addon/globalPlugins/YoutubePlus/core.py:1324
msgid "Adding playlist to favorites..."
msgstr "กำลังเพิ่มเพลย์ลิสต์ในรายการโปรด..."

#. Translators: Message shown when the user tries to add a playlist that is already in their favorites list.
#: addon/globalPlugins/YoutubePlus/core.py:1347
msgid "This playlist is already in your favorites."
msgstr "เพลย์ลิสต์นี้อยู่ในรายการโปรดของคุณแล้ว"

#. Translators: Fallback title used when the actual name of the playlist cannot be retrieved.
#: addon/globalPlugins/YoutubePlus/core.py:1351
msgid "Unknown Playlist"
msgstr "เพลย์ลิสต์ที่ไม่รู้จัก"

#. Translators: Success message shown after a playlist has been added to favorites. {playlist} is the title of the playlist.
#: addon/globalPlugins/YoutubePlus/core.py:1365
#, python-brace-format
msgid "Added '{playlist}' to favorites."
msgstr "เพิ่ม '{playlist}' ลงในรายการโปรด"

#. Translators: Error message shown when the process of adding a playlist to favorites fails for any reason.
#: addon/globalPlugins/YoutubePlus/core.py:1368
msgid "Failed to add favorite playlist."
msgstr "ไม่สามารถเพิ่มเพลย์ลิสต์โปรด"

#. Translators: Message shown when a video cannot be added because it already exists in the Watch List. {title} is the video title.
#: addon/globalPlugins/YoutubePlus/core.py:1424
#, python-brace-format
msgid "'{title}' is already in Watch List."
msgstr "'{title}' อยู่ในรายการเฝ้าดูแล้ว"

#. Translators: Success message shown when a video is successfully added to the Watch List. {title} is the video title.
#: addon/globalPlugins/YoutubePlus/core.py:1437
#, python-brace-format
msgid "Added '{title}' to Watch List."
msgstr "เพิ่ม '{title}' ในรายการเฝ้าดู"

#. Translators: Error message shown when the add-on fails to save the video to the Watch List file.
#: addon/globalPlugins/YoutubePlus/core.py:1445
msgid "Error: Could not add video to Watch List."
msgstr "ข้อผิดพลาด: ไม่สามารถเพิ่มวิดีโอลงในรายการเฝ้าดูได้"

#. Translators: Abbreviation for "Not Available", used when a video title cannot be found.
#. Translators: Abbreviation for "Not Available".
#. Translators: Default text when no description is available.
#. Translators: Default text for playlist title or channel if missing.
#. Translators: Default text for a video title if it's missing.
#. Translators: Default text for missing video information.
#: addon/globalPlugins/YoutubePlus/core.py:1493 addon/globalPlugins/YoutubePlus/core.py:1861
#: addon/globalPlugins/YoutubePlus/dialogs.py:1449
#: addon/globalPlugins/YoutubePlus/dialogs.py:1504
#: addon/globalPlugins/YoutubePlus/dialogs.py:1850
#: addon/globalPlugins/YoutubePlus/dialogs.py:2196
#: addon/globalPlugins/YoutubePlus/dialogs.py:2798
msgid "N/A"
msgstr "ไม่มี"

#. Translators: Error message shown when a channel or playlist is empty or no videos can be retrieved.
#: addon/globalPlugins/YoutubePlus/core.py:1503
msgid "No videos found."
msgstr "ไม่พบวิดีโอ"

#. Translators: Title of the video list dialog for a playlist.
#. {count} is the number of videos, {playlist} is the playlist name.
#: addon/globalPlugins/YoutubePlus/core.py:1510
#, python-brace-format
msgid "{count} videos in {playlist}"
msgstr "{count}วิดีโอใน{playlist}"

#: addon/globalPlugins/YoutubePlus/core.py:1510
msgid "Playlist"
msgstr "เพลย์ลิสต์"

#. Translators: Title of the video list dialog for a channel.
#. {count} is the number of videos, {type} is the content type (e.g., videos/shorts), {channel} is the channel name.
#: addon/globalPlugins/YoutubePlus/core.py:1514
#, python-brace-format
msgid "Recent {count} {type} from {channel}"
msgstr "{count}{type}ล่าสุดจาก{channel}"

#. Translators: Label shown in search results to indicate the item is a YouTube channel.
#. Translators: Column header for channel name.
#. Translators: Column header for the name of the channel/uploader.
#: addon/globalPlugins/YoutubePlus/core.py:1514 addon/globalPlugins/YoutubePlus/core.py:1869
#: addon/globalPlugins/YoutubePlus/dialogs.py:1129
#: addon/globalPlugins/YoutubePlus/dialogs.py:1399
#: addon/globalPlugins/YoutubePlus/dialogs.py:1663
msgid "Channel"
msgstr "ช่อง"

#. Translators: Error message shown when the add-on fails to download the list of videos from YouTube.
#: addon/globalPlugins/YoutubePlus/core.py:1529
msgid "Failed to fetch video list."
msgstr "ไม่สามารถเรียกรายการวิดีโอ"

#. Translators: Status message shown when the add-on begins the process of subscribing to a YouTube channel.
#: addon/globalPlugins/YoutubePlus/core.py:1537
msgid "Subscribing to channel..."
msgstr "กำลังติดตามช่อง..."

#. Translators: A confirmation prompt shown when the user tries to subscribe to a channel they are already subscribed to.
#. {channel} is the name of the YouTube channel.
#: addon/globalPlugins/YoutubePlus/core.py:1565
#, python-brace-format
msgid ""
"You are already subscribed to '{channel}'.\n"
"Would you like to unsubscribe instead?"
msgstr ""
"คุณได้สมัครรับข้อมูลจาก '{channel}' แล้ว\n"
"คุณต้องการยกเลิกการสมัครแทนหรือไม่?"

#. Translators: The title of the confirmation dialog when a user is already subscribed to a channel.
#: addon/globalPlugins/YoutubePlus/core.py:1567
msgid "Already Subscribed"
msgstr "สมัครสมาชิกแล้ว"

#. Translators: Fallback name used when the YouTube channel name cannot be identified.
#: addon/globalPlugins/YoutubePlus/core.py:1588
msgid "Unknown Channel"
msgstr "ช่องที่ไม่รู้จัก"

#. Translators: Success message shown after successfully subscribing to a YouTube channel.
#. {channel} is the name of the channel.
#: addon/globalPlugins/YoutubePlus/core.py:1603
#, python-brace-format
msgid "Subscribed to {channel}."
msgstr "ติดตาม{channel}"

#. Translators: Error message shown when the subscription process fails.
#: addon/globalPlugins/YoutubePlus/core.py:1606
msgid "Failed to subscribe."
msgstr "สมัครสมาชิกไม่สำเร็จ"

#. Translators: Success message shown after successfully unsubscribing from a YouTube channel.
#. {channel} is the name of the channel.
#: addon/globalPlugins/YoutubePlus/core.py:1626
#, python-brace-format
msgid "Successfully unsubscribed from {channel}"
msgstr "ยกเลิกการสมัครจาก{channel}สำเร็จแล้ว"

#. Translators: Error message shown when trying to unsubscribe from a channel that isn't in the database.
#: addon/globalPlugins/YoutubePlus/core.py:1629
msgid "Failed to unsubscribe - channel not found in database"
msgstr "ไม่สามารถยกเลิกการสมัคร - ไม่พบช่องในฐานข้อมูล"

#. Translators: Error message shown when an unexpected database or system error occurs during unsubscription.
#: addon/globalPlugins/YoutubePlus/core.py:1633
msgid "Critical error during unsubscribe."
msgstr "เกิดข้อผิดพลาดร้ายแรงระหว่างการยกเลิกการสมัคร"

#. Translators: Progress message shown when no channels are available for update.
#. Translators: Message shown when the user tries to update the feed but hasn't subscribed to any channels.
