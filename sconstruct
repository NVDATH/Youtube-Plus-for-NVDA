# -*- coding: utf-8 -*-
import codecs
import os
import os.path
import zipfile
import sys
import subprocess
import shutil
import gettext
from SCons.Script import Variables, BoolVariable, Environment, Builder, Copy

sys.dont_write_bytecode = True
import buildVars

# ---------- Markdown to HTML ----------
def md2html(source, dest):
    import markdown
    lang = os.path.basename(os.path.dirname(source)).replace('_', '-')
    title = "{addonSummary} {addonVersion}".format(
        addonSummary=buildVars.addon_info["addon_summary"],
        addonVersion=buildVars.addon_info["addon_version"]
    )
    with codecs.open(source, "r", "utf-8") as f:
        mdText = f.read()
        htmlText = markdown.markdown(mdText)
    with codecs.open(dest, "w", "utf-8") as f:
        f.write("<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n"
                "<!DOCTYPE html PUBLIC \"-//W3C//DTD XHTML 1.0 Strict//EN\"\n"
                "    \"http://www.w3.org\">\n"
                "<html xmlns=\"http://www.w3.org\" xml:lang=\"%s\" lang=\"%s\">\n" % (lang, lang) +
                "<head>\n"
                "<meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\"/>\n"
                "<link rel=\"stylesheet\" type=\"text/css\" href=\"../style.css\" media=\"screen\"/>\n"
                "<title>%s</title>\n" % title +
                "</head>\n<body>\n"
        )
        f.write(htmlText)
        f.write("\n</body>\n</html>")

def mdTool(env):
    mdAction = env.Action(
        lambda target, source, env: md2html(source[0].path, target[0].path),
        lambda target, source, env: 'Generating %s' % target[0],
    )
    mdBuilder = env.Builder(action=mdAction, suffix='.html', src_suffix='.md')
    env['BUILDERS']['markdown'] = mdBuilder

# ---------- Localization Helpers ----------
def generateTranslatedManifest(source, language, out):
    # พยายามดึงคำแปลจากไฟล์ nvda.mo ในโฟลเดอร์ภาษานั้นๆ
    addon_id = "nvda" 
    try:
        _ = gettext.translation(addon_id, localedir=os.path.join("addon", "locale"), languages=[language]).gettext
        vars = {
            "addon_summary": _(buildVars.addon_info["addon_summary"]),
            "addon_description": _(buildVars.addon_info["addon_description"]),
        }
    except Exception:
        vars = {
            "addon_summary": buildVars.addon_info["addon_summary"],
            "addon_description": buildVars.addon_info["addon_description"],
        }
    
    with codecs.open(source, "r", "utf-8") as f:
        template = f.read()
    with codecs.open(out, "w", "utf-8") as f:
        f.write(template.format(**vars))

def translatedManifestGenerator(target, source, env, for_signature):
    lang = os.path.basename(os.path.dirname(str(target[0])))
    return env.Action(
        lambda target, source, env: generateTranslatedManifest(source[0].abspath, lang, target[0].abspath) and None,
        lambda target, source, env: f"Generating translated manifest for {lang}"
    )

# ---------- Environment Setup ----------
vars = Variables()
vars.Add("version", "The version of this build", buildVars.addon_info["addon_version"])
vars.Add(BoolVariable("dev", "Whether this is a daily development version", False))

# เพิ่ม gettexttool เข้าไปใน tools
env = Environment(variables=vars, ENV=os.environ, tools=["gettexttool", mdTool])
env.Append(**buildVars.addon_info)
env['BUILDERS']['NVDATranslatedManifest'] = Builder(generator=translatedManifestGenerator)

if env["dev"]:
    import datetime
    buildDate = datetime.datetime.now()
    env["addon_version"] = buildDate.strftime("%Y%m%d") + "-dev"
elif env["version"] is not None:
    env["addon_version"] = env["version"]

addonFile = env.File("${addon_name}-${addon_version}.nvda-addon")

# ---------- Pre-build: Pip install & Cleanup ----------
lib_dir = os.path.join("addon", "globalPlugins", "YoutubePlus", "lib")
if not os.path.exists(lib_dir): os.makedirs(lib_dir)

subprocess.check_call([sys.executable, "-m", "pip", "install", "--upgrade", "-r", "requirements.txt", "--target", lib_dir, "--no-deps"])

for item in os.listdir(lib_dir):
    path = os.path.join(lib_dir, item)
    if (item.endswith(".dist-info") or item in ["bin", "share", "testrun"]) and os.path.isdir(path):
        shutil.rmtree(path)

# Security Patch for bunnycdn.py
bunny_file = os.path.join(lib_dir, "yt_dlp", "downloader", "bunnycdn.py")
if os.path.exists(bunny_file):
    with open(bunny_file, "r", encoding="utf-8") as f: lines = f.readlines()
    with open(bunny_file, "w", encoding="utf-8") as f:
        for i, line in enumerate(lines):
            f.write(f"# Fixed: {line}" if i + 1 in [32, 44] else line)

# ---------- POT Generation ----------
def generatePot(target, source, env):
    addon_id = "nvda"
    pot_file = os.path.join("addon", "locale", f"{addon_id}.pot")
    if not os.path.exists(os.path.dirname(pot_file)): os.makedirs(os.path.dirname(pot_file))
    
    cmd = (f'xgettext --package-name="YoutubePlus" --add-comments="Translator:" '
           f'--output={pot_file} --language=Python --keyword=_ --from-code=utf-8 '
           f'addon/globalPlugins/YoutubePlus/*.py addon/*.py')
    return subprocess.call(cmd, shell=True)

env.Alias('pot', [], generatePot)

# ---------- Add-on Bundle & Manifest ----------
def createAddonBundleFromPath(path, dest):
    basedir = os.path.abspath(path)
    with zipfile.ZipFile(dest, 'w', zipfile.ZIP_DEFLATED) as z:
        for dir, _, filenames in os.walk(basedir):
            for filename in filenames:
                absPath = os.path.join(dir, filename)
                relPath = os.path.relpath(absPath, basedir)
                if relPath not in buildVars.excludedFiles:
                    z.write(absPath, relPath)
    return dest

env['BUILDERS']['NVDAAddon'] = Builder(
    action=env.Action(lambda target, source, env: createAddonBundleFromPath(source[0].abspath, target[0].abspath) and None,
                      lambda target, source, env: "Generating Addon %s" % target[0])
)

# ---------- Build Process ----------
addon = env.NVDAAddon(addonFile, env.Dir('addon'))

# Manage Locale & Translated Manifests
for langDir in env.Glob(os.path.join('addon', 'locale', '*')):
    lang = os.path.basename(str(langDir))
    if not os.path.isdir(str(langDir)) or lang == "en": continue
    
    # สร้าง manifest.ini จาก template
    t_manifest = env.NVDATranslatedManifest(
        os.path.join(str(langDir), 'manifest.ini'),
        'manifest-translated.ini'
    )
    env.Depends(addon, t_manifest)

# Help Docs
for mdFile in env.Glob(os.path.join('addon', 'doc', '*', '*.md')):
    htmlFile = env.markdown(mdFile)
    env.Depends(addon, htmlFile)

# Final dependencies
env.Depends(addon, env.Glob(os.path.join('addon', '*.py')))
